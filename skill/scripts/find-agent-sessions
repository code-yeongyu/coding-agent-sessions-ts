#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"

resolve_repo_root() {
  if [[ -n "${CODING_AGENT_SESSIONS_TS_ROOT:-}" ]]; then
    printf '%s\n' "$CODING_AGENT_SESSIONS_TS_ROOT"
    return 0
  fi

  if [[ -f "$SKILL_DIR/.repo-root" ]]; then
    sed -n '1p' "$SKILL_DIR/.repo-root"
    return 0
  fi

  if [[ -f "$SKILL_DIR/../package.json" ]]; then
    printf '%s\n' "$(cd -- "$SKILL_DIR/.." && pwd)"
    return 0
  fi

  if [[ -d "$HOME/local-workspaces/coding-agent-sessions-ts" ]]; then
    printf '%s\n' "$HOME/local-workspaces/coding-agent-sessions-ts"
    return 0
  fi

  return 1
}

REPO_ROOT="$(resolve_repo_root || true)"
if [[ -z "$REPO_ROOT" || ! -f "$REPO_ROOT/dist/cli.js" ]]; then
  cat >&2 <<'EOF'
coding-agent-sessions TypeScript CLI is not built or cannot be found.

Fix:
  cd /path/to/coding-agent-sessions-ts
  pnpm install
  pnpm build
  printf '%s\n' "$PWD" > ~/.agents/skills/coding-agent-sessions/.repo-root
EOF
  exit 127
fi

exec node "$REPO_ROOT/dist/cli.js" "$@"
